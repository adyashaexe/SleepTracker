<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center_horizontal">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SLEEP"
            android:textSize="11sp"
            android:textColor="#5B6B8A"
            android:letterSpacing="0.4"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-medium"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tracker"
            android:textSize="36sp"
            android:textColor="#E8EDF5"
            android:fontFamily="serif"
            android:layout_marginTop="2dp"/>

        <!-- Moon icon placeholder (decorative divider) -->
        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:background="#1E3A5F"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="32dp"/>

        <!-- Clock card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/card_bg"
            android:padding="32dp"
            android:elevation="8dp">

            <TextView
                android:id="@+id/stageText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Not Tracking"
                android:textSize="13sp"
                android:textColor="#5B8FA8"
                android:letterSpacing="0.2"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="12dp"/>

            <Chronometer
                android:id="@+id/chronometer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="56sp"
                android:textColor="#E8EDF5"
                android:gravity="center"
                android:format="%s"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="-0.02"/>

            <!-- Subtle pulse ring (decorative) -->
            <View
                android:layout_width="80dp"
                android:layout_height="1dp"
                android:background="#1A2E45"
                android:layout_marginTop="20dp"/>

        </LinearLayout>

        <!-- Stage indicator pills row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AWAKE"
                android:textSize="9sp"
                android:textColor="#2A3A52"
                android:letterSpacing="0.3"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:background="@drawable/pill_bg"
                android:fontFamily="sans-serif-medium"/>

            <View
                android:layout_width="16dp"
                android:layout_height="1dp"
                android:background="#1A2E45"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="N1"
                android:textSize="9sp"
                android:textColor="#2A3A52"
                android:letterSpacing="0.3"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:background="@drawable/pill_bg"
                android:fontFamily="sans-serif-medium"/>

            <View
                android:layout_width="16dp"
                android:layout_height="1dp"
                android:background="#1A2E45"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="N2"
                android:textSize="9sp"
                android:textColor="#2A3A52"
                android:letterSpacing="0.3"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:background="@drawable/pill_bg"
                android:fontFamily="sans-serif-medium"/>

            <View
                android:layout_width="16dp"
                android:layout_height="1dp"
                android:background="#1A2E45"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="N3"
                android:textSize="9sp"
                android:textColor="#2A3A52"
                android:letterSpacing="0.3"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:background="@drawable/pill_bg"
                android:fontFamily="sans-serif-medium"/>

            <View
                android:layout_width="16dp"
                android:layout_height="1dp"
                android:background="#1A2E45"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REM"
                android:textSize="9sp"
                android:textColor="#2A3A52"
                android:letterSpacing="0.3"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:background="@drawable/pill_bg"
                android:fontFamily="sans-serif-medium"/>

        </LinearLayout>

        <!-- Primary action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="28dp"
            android:weightSum="2">

            <Button
                android:id="@+id/startBtn"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Start"
                android:textColor="#0A0E1A"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:backgroundTint="#7EB8D4"
                android:stateListAnimator="@null"
                android:elevation="0dp"/>

            <Button
                android:id="@+id/stopBtn"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Stop"
                android:textColor="#0A0E1A"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:backgroundTint="#E07B6A"
                android:stateListAnimator="@null"
                android:elevation="0dp"
                android:enabled="false"/>

        </LinearLayout>

        <!-- Secondary buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:weightSum="2">

            <Button
                android:id="@+id/resetBtn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Reset"
                android:textColor="#5B6B8A"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:backgroundTint="#111827"
                android:stateListAnimator="@null"
                android:elevation="0dp"/>

            <Button
                android:id="@+id/settingsBtn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Set Goal"
                android:textColor="#5B6B8A"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:backgroundTint="#111827"
                android:stateListAnimator="@null"
                android:elevation="0dp"/>

        </LinearLayout>

        <!-- Bottom hint -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="tap start when you go to bed"
            android:textSize="11sp"
            android:textColor="#2A3A52"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="16dp"
            android:fontFamily="sans-serif"/>

    </LinearLayout>
</ScrollView>